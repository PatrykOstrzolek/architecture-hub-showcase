{% extends 'base.html.twig' %}

{# Fallback HTML view — the public experience is rendered by Next.js against the
   headless JSON (`/.json`); this view only needs to stay valid. #}
{% block content %}
    <h1>{{ content.title }}</h1>

    {% if content.intro %}
        <p>{{ content.intro }}</p>
    {% endif %}

    {% if content.questions %}
        <ol>
            {% for question in content.questions %}
                <li>{{ question.question }}</li>
            {% endfor %}
        </ol>
    {% endif %}
{% endblock %}
