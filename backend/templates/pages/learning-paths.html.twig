{% extends 'base.html.twig' %}

{# Fallback HTML view — the public experience is rendered by Next.js against the
   headless JSON (`/.json`); this view only needs to stay valid. #}
{% block content %}
    <h1>{{ content.title }}</h1>

    {% if content.paths %}
        <ul>
            {% for path in content.paths %}
                <li><a href="{{ path.url }}">{{ path.title }}</a></li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
