<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>learning-path</key>

    <view>pages/learning-path</view>
    <controller>Sulu\Bundle\HeadlessBundle\Controller\HeadlessWebsiteController::indexAction</controller>
    <cacheLifetime>86400</cacheLifetime>

    <meta>
        <title lang="en">Learning Path</title>
        <title lang="de">Lernpfad</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
            <tag name="sulu.search.field" role="title"/>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
        </property>

        <!-- Short description shown on the listing page and as the lead on the detail page. -->
        <property name="description" type="text_area" mandatory="true">
            <meta>
                <title lang="en">Description</title>
                <title lang="de">Beschreibung</title>
                <info_text lang="en">Short description of this learning path (shown in listings and at the top of the path page).</info_text>
            </meta>

            <tag name="sulu.search.field" role="description"/>
        </property>

        <!-- Ordered article sequence. Editors drag-and-drop to set the reading order. -->
        <property name="articles" type="article_selection">
            <meta>
                <title lang="en">Articles</title>
                <title lang="de">Artikel</title>
                <info_text lang="en">Articles in this learning path, in reading order.</info_text>
            </meta>
            <params>
                <param name="properties" type="collection">
                    <param name="summary" value="summary"/>
                </param>
            </params>
        </property>

        <!-- Optional link to a quiz page under this path. See ADR 0011. -->
        <property name="exercise" type="single_page_selection" mandatory="false">
            <meta>
                <title lang="en">Exercise</title>
                <title lang="de">Übung</title>
                <info_text lang="en">Optional quiz page for this learning path.</info_text>
            </meta>
        </property>
    </properties>
</template>
