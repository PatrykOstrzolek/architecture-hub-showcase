<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>author</key>

    <view>pages/author</view>
    <controller>Sulu\Bundle\HeadlessBundle\Controller\HeadlessWebsiteController::indexAction</controller>
    <cacheLifetime>604800</cacheLifetime>

    <meta>
        <title lang="en">Author profile</title>
        <title lang="de">Autorenprofil</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
                <info_text lang="en">The author's display name (also used for the URL).</info_text>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
            <tag name="sulu.search.field" role="title"/>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
        </property>

        <!-- The author identity: a built-in Contact (name, note→bio, avatar, position). -->
        <property name="contact" type="single_contact_selection" mandatory="true">
            <meta>
                <title lang="en">Author (Contact)</title>
                <title lang="de">Autor (Kontakt)</title>
                <info_text lang="en">The Contact whose name, bio (note), avatar and position back this profile.</info_text>
            </meta>
        </property>

        <!-- The author's articles, in a curated order (manual reverse relation, see ADR 0004). -->
        <property name="articles" type="article_selection">
            <meta>
                <title lang="en">Articles</title>
                <title lang="de">Artikel</title>
                <info_text lang="en">Articles written by this author, in display order.</info_text>
            </meta>
        </property>
    </properties>
</template>
